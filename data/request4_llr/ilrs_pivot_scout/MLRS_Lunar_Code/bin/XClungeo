# Script to perform lunar predictions and to copy them to CDDIS and EDC.
#
# R. Ricklefs / UT/CSR	 05 Jan 2005
# Updated from cddisin 06/22/10 rlr
#===========================================================================
# Go somewhere neutral
#cd /tmp
#
# Create predictions
#~/MLRS_Lunar_Code/prod/bin/genpred -a5 -f PRDCTRL.PCAg21
bin/genpred -a5 -f PRDCTRL.PCAg21
#
# Add comments 
for i in `ls *cpf*.utx`
do
  mv $i $i.tmp
  #cp ~/MLRS_Lunar_Code/prod/data/lib/comment.llr.421  $i
  cp data/lib/comment.llr.421  $i
  cat $i.tmp >> $i
done

# archive them someplace
#mv *cpf*.utx ~/MLRS_Lunar_Code/prod/data/llr/pred/421
mv *cpf*.utx data/pred/421
rm -f *.tmp Prd-debug
exit
#
# Copy to cddis
trap ':' 1 2 3 15
#ftp -i -n -v > ~/MLRS_Lunar_Code/prod/data/log/luncddis.log <<-EOF
ftp -i -n -v > data/log/luncddis.log <<-EOF
open cddisin.gsfc.nasa.gov
user xxx yyy
bin
cd cpf
mput *cpf*.utx
quit
EOF

# Copy to edc
trap ':' 1 2 3 15
#ftp -i -n -v > ~/MLRS_Lunar_Code/prod/data/log/lunedc.log <<-EOF
ftp -i -n -v > data/log/lunedc.log <<-EOF
open edc.dgfi.badw.de
user xxx yyy
bin
mput *cpf*.utx
quit
EOF

# archive them someplace
#mv *cpf*.utx ~/MLRS_Lunar_Code/prod/data/llr/pred/421
mv *cpf*.utx data/pred/421
