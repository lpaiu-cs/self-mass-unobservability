#
#  Get the latest USNO (IERS) Bulletin A via ftp from the usno
#  and ftp it to the MLRS analysis computer. This is not done directly
#  from the controller as this system may be limited to communicating 
#  with the local network, for security reasons.
#  R. Ricklefs 10/96
#
#  History:
#	10/21/09 - Changed "complete" to "OK" below as ftp no longer 
#		   says "complete". rlr.
#       01/17/17 - Modify for open source distribution. rlr.
#
######################################################################
getfile() {
echo "Logging on to USNO computer" >> ${FTPLOG}
trap ':' 1 2 3 15
ftp -i -v -n <<-EOF >> ${FTPLOG}
open maia.usno.navy.mil
binary
hash
user anonymous xxx@yyy.zzz
cd ser7
get mark3.out
quit
EOF
} # end getfile

#############################
#  Start executable code
#############################
FTPLOG="../log/ftpbulla.log";   export FTPLOG
cd data/lib
rm ${FTPLOG} > /dev/null
echo "Updating Earth Orientation predicts." >> ${FTPLOG}
getfile
# Changed to "OK" on 10/21/09. "complete" no longer in log.
# Changed back to "complete" on 02/20/15 "OK" no longer in log.
grepstring=`grep complete ${FTPLOG}`
#grepstring=`grep OK ${FTPLOG}`
if test -z "$grepstring"
  then
  echo "\nDownload apparently failed!" >> ${FTPLOG}
  date >> ${FTPLOG}
  exit 1
else
  echo "\nDownload succeeded" >> ${FTPLOG}
  date >> ${FTPLOG}
fi

# Save old poldat file
mv poldat poldat_old

# Convert input file to a format we like
/prod/bin/BullA <mark3.out >poldat

f1=`date +%m%d%y`
cp poldat poldat_$f1

# Tell someone...
#mail -s "Bull A retrieval" xxx < ${FTPLOG}
# end XCgetBullAM
